---
# Kubernetes Secrets for Database and RabbitMQ credentials
# Copy this file to secrets.yaml and replace placeholder values with your own base64-encoded credentials
# Example: echo -n "your_password" | base64

apiVersion: v1
kind: Secret
metadata:
  name: inventory-db-secret
  namespace: default
type: Opaque
data:
  POSTGRES_PASSWORD: <base64-encoded-password>
  POSTGRES_USER: <base64-encoded-username>
  POSTGRES_DB: <base64-encoded-dbname>

---
apiVersion: v1
kind: Secret
metadata:
  name: billing-db-secret
  namespace: default
type: Opaque
data:
  POSTGRES_PASSWORD: <base64-encoded-password>
  POSTGRES_USER: <base64-encoded-username>
  POSTGRES_DB: <base64-encoded-dbname>

---
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-secret
  namespace: default
type: Opaque
data:
  RABBITMQ_DEFAULT_USER: <base64-encoded-username>
  RABBITMQ_DEFAULT_PASS: <base64-encoded-password>
  RABBITMQ_HOST: <base64-encoded-host>
  RABBITMQ_PORT: <base64-encoded-port>
  RABBITMQ_QUEUE: <base64-encoded-queue>
